{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Microsoft.AspNetCore.Watch.BrowserRefresh": "None",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.AspNetCore.Watch": "Warning",
      "System": "Warning"
    }
  },
  "AllowedHosts": "*",
  "RateLimit": {
    "CareerEndpoint": {
      "PermitLimit": 100,
      "Window": "00:01:00",
      "QueueLimit": 50
    },
    "Global": {
      "PermitLimit": 1000,
      "Window": "00:01:00",
      "QueueLimit": 100
    }
  },
  "Cache": {
    "MaxCacheSize": 1000,
    "DefaultExpiration": "00:30:00",
    "LongExpiration": "02:00:00",
    "RedisEnabled": false,
    "FallbackEnabled": true
  },
  "ExternalServices": {
    "EmployeeService": {
      "BaseUrl": "http://localhost:8080",
      "TimeoutInSeconds": 30
    },
    "UploadService": {
      "BaseUrl": "http://localhost:8081",
      "TimeoutInSeconds": 30
    },
    "CountryService": {
      "BaseUrl": "http://localhost:8082",
      "TimeoutInSeconds": 30
    },
    "EmailService": {
      "BaseUrl": "http://localhost:8083",
      "TimeoutInSeconds": 30
    }
  }
}