{
  "RateLimit": {
    "CareerEndpoint": {
      "PermitLimit": 100,
      "Window": "00:01:00",
      "QueueLimit": 50
    },
    "Global": {
      "PermitLimit": 1000,
      "Window": "00:01:00",
      "QueueLimit": 100
    }
  },
  "Cache": {
    "MaxCacheSize": 1000
  },
  "Cors": {
    "AllowedOrigins": [
      "https://maliev.com",
      "https://*.maliev.com",
      "http://maliev.com",
      "http://*.maliev.com"
    ]
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}]] {CorrelationId} {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/career-service-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 31,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {CorrelationId} {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithEnvironmentName", "WithMachineName", "WithProcessId", "WithThreadId" ],
    "Filter": [
      {
        "Name": "ByExcluding",
        "Args": {
          "expression": "RequestPath like '/health%' or RequestPath like '/metrics%'"
        }
      }
    ]
  },
  "AllowedHosts": "*"
}