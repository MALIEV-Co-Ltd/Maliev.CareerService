{
  "RateLimit": {
    "CareerEndpoint": {
      "PermitLimit": 100,
      "Window": "00:01:00",
      "QueueLimit": 50
    },
    "Global": {
      "PermitLimit": 1000,
      "Window": "00:01:00",
      "QueueLimit": 100
    }
  },
  "Cache": {
    "MaxCacheSize": 1000
  },
  "Cors": {
    "AllowedOrigins": [
      "https://maliev.com",
      "https://*.maliev.com",
      "http://maliev.com",
      "http://*.maliev.com"
    ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}