{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Microsoft.AspNetCore.Watch.BrowserRefresh": "None",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.AspNetCore.Watch": "Warning",
      "System": "Warning"
    }
  },
  "AllowedHosts": "*",
  "RateLimit": {
    "CareerEndpoint": {
      "PermitLimit": 100,
      "Window": "00:01:00",
      "QueueLimit": 50
    },
    "Global": {
      "PermitLimit": 1000,
      "Window": "00:01:00",
      "QueueLimit": 100
    }
  },
  "Cache": {
    "MaxCacheSize": 1000,
    "DefaultExpiration": "00:30:00",
    "LongExpiration": "02:00:00",
    "RedisEnabled": true,
    "FallbackEnabled": true
  },
  "Services": {
    "EmployeeService": {
      "BaseUrl": "http://maliev-employeeservice-api"
    },
    "UploadService": {
      "BaseUrl": "http://maliev-uploadservice-api"
    },
    "CountryService": {
      "BaseUrl": "http://maliev-countryservice-api"
    },
    "NotificationService": {
      "BaseUrl": "http://maliev-notificationservice-api"
    },
    "IAMService": {
      "BaseUrl": "http://maliev-iamservice-api"
    }
  }
}